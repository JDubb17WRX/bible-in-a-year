# Bible in a Year environment template.
# Copy to .env on the server or development machine and replace all secrets.
# Never commit real values here — this file is tracked in git.

NODE_ENV=production
APP_BASE_URL=https://bible.rpcnacovenanters.com

# The main Covenanters site this app borrows login from. It must expose
# GET /api/session/whoami (reads its own session cookie, returns the caller's
# identity) and its /community/login page must accept a same-domain
# ?returnTo= redirect param.
COVENANTERS_APP_URL=https://rpcnacovenanters.com
COVENANTERS_LOGIN_URL=https://rpcnacovenanters.com/community/login

# Free, non-commercial API key from https://api.esv.org/account/create-application/
# Required for ESV passage text. Never exposed to the browser — only read
# server-side in src/app/api/passage/route.ts.
ESV_API_KEY=

# No key needed: bible-api.com serves the public-domain World English Bible.
# Left as an env var only so the upstream host is easy to change later.
WEB_TRANSLATION_API_BASE=https://bible-api.com

# Where the SQLite database file lives inside the container. The VPS compose
# file bind-mounts ./data on the host to this path so it survives rebuilds.
SQLITE_DB_PATH=/app/data/bible.sqlite
