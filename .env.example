# Bible in a Year environment template.
# Copy to .env on the server or development machine and replace all secrets.

NODE_ENV=production
APP_BASE_URL=https://bible.rpcnacovenanters.com
COVENANTERS_APP_URL=https://rpcnacovenanters.com
COVENANTERS_LOGIN_URL=https://rpcnacovenanters.com/community/login
ESV_API_KEY=dbdb5fdae659512264c586a92edf8c52ef242424
WEB_TRANSLATION_API_BASE=https://bible-api.com
# Where the SQLite database file lives inside the container. The VPS compose
# file bind-mounts ./data on the host to this path so it survives rebuilds.
SQLITE_DB_PATH=/app/data/bible.sqlite
